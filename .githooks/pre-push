#!/usr/bin/env bash
#
# pre-push — 推送前本地完整构建
#
# 在 git push 前执行 scripts/build-release.sh，构建失败则阻止推送，
# 确保推送的代码可编译、可产出完整发布产物。
#
# 跳过本次构建：
#   NEWAPI_SKIP_BUILD=1 git push   或   git push --no-verify
#
set -euo pipefail

if [ "${NEWAPI_SKIP_BUILD:-}" = "1" ]; then
  echo "[pre-push] NEWAPI_SKIP_BUILD=1，跳过本地构建。"
  exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
SCRIPT="$REPO_ROOT/scripts/build-release.sh"

if [ ! -x "$SCRIPT" ]; then
  echo "[pre-push] 未找到可执行的 $SCRIPT，跳过。" >&2
  exit 0
fi

echo "[pre-push] 开始本地完整构建（跳过可用 --no-verify 或 NEWAPI_SKIP_BUILD=1）..."
if ! "$SCRIPT"; then
  echo "[pre-push] 构建失败，已阻止推送。" >&2
  exit 1
fi
echo "[pre-push] 构建通过，允许推送。"
exit 0
